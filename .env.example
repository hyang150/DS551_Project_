# ============================================================
#  Environment variable template for Stock Market Analytics
#  Copy to .env and fill in your local credentials:
#      cp .env.example .env
#
#  All values below are OPTIONAL — the scripts fall back to the
#  defaults shown here when a variable is unset, so you only need
#  to edit what differs from your machine.
# ============================================================

# --- MySQL ------------------------------------------------------
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=stock_db

# --- MongoDB ----------------------------------------------------
# Leave MONGO_URI default (mongodb://127.0.0.1:27017) for local dev.
# For a remote cluster: mongodb+srv://user:pass@cluster.example.net
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=stock_db
MONGO_COLLECTION=stock_data
